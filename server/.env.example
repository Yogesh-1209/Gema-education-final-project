# Server
NODE_ENV=development
PORT=3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/gema-education

# CORS — comma-separated origins (frontend dev server)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT Authentication
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
